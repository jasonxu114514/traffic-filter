{
  "engine": "nfqueue",
  "debug": false,
  "stats_interval": "5s",
  "rules": {
    "domains": ["example.com"],
    "dns_poison_domains": ["example.com"],
    "ips": ["203.0.113.10", "198.51.100.0/24", "2001:db8::/32"],
    "ip_ports": [
      { "ip": "1.2.3.4", "port": 443, "proto": "tcp" },
      { "ip": "2001:db8::1", "port": 443, "proto": "tcp" }
    ]
  },
  "nfqueue": {
    "queue_num": 100,
    "firewall_backend": "auto",
    "install_rules": true,
    "chains": ["input", "output", "forward"],
    "capture": "l7",
    "fail_open": false,
    "dns_mode": "nxdomain"
  },
  "af_xdp": {
    "iface": "ens18",
    "mode": "disabled"
  }
}
